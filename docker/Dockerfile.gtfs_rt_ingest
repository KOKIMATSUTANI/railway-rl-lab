FROM python:3.13-slim

# Python settings
ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

# Work directory
WORKDIR /app

# Install uv
RUN pip install --no-cache-dir uv

# Copy dependency files first (use Docker layer cache)
COPY pyproject.toml ./
COPY uv.lock* ./

# Install dependencies
RUN uv sync --no-dev

# Copy project
COPY . .

# Default command
CMD ["uv", "run", "python", "src/gtfs/ingest_gtfs_rt.py"]